# ESP32-C6 目标芯片配置
CONFIG_IDF_TARGET="esp32c6"

# USB 控制台配置（ESP32-C6 使用内置 USB Serial/JTAG 控制器）
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_ESP_CONSOLE_UART_NONE=y

# USB Serial/JTAG 驱动配置（关键：确保驱动正确初始化）
CONFIG_USB_SERIAL_JTAG=y

# USB PHY 支持（ESP32-C6 必需）
CONFIG_ESP_PHY_ENABLE_USB=y

# WiFi 配置
CONFIG_ESP_WIFI_ENABLED=y
CONFIG_WPA_MBEDTLS_CRYPTO=y

# MQTT 配置
CONFIG_MQTT_PROTOCOL_311=y
CONFIG_MQTT_TRANSPORT_SSL=n
CONFIG_MQTT_TRANSPORT_WEBSOCKET=n

# NVS Flash 配置
CONFIG_NVS_FLASH_ENCRYPTION=n

# LEDC PWM 配置（ESP32-C6使用LEDC）
CONFIG_LEDC_SUPPORT_APB_CLOCK=y

# SmartConfig (AirKiss) 配置
CONFIG_ESP_SMARTCONFIG_ENABLE=y

# 日志级别
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# 分区表配置
CONFIG_PARTITION_TABLE_SINGLE_APP=y

# 编译器优化（暂时禁用以便调试）
# CONFIG_OPTIMIZATION_LEVEL_RELEASE=y
CONFIG_OPTIMIZATION_LEVEL_DEBUG=y

# 启用TinyUSB CDC ACM（如果使用TinyUSB需要此配置）
# CONFIG_TINYUSB_CDC_ENABLED=y
